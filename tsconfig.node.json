{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "types": ["node", "electron"],
    "strict": true
  },
  "include": ["vite.config.ts", "electron.vite.config.ts", "electron/**/*.ts"]
}
